# Copie para backend/.env e ajuste os valores. NUNCA versione o .env real.

# Conexão PostgreSQL
DATABASE_URL=postgres://usuario:senha@localhost:5432/protocolo_sepse

# Segredo de assinatura dos tokens JWT (mínimo 16 caracteres; use um valor aleatório e único).
# Ex.: gere com  openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-aleatorio-longo

# Validade do token de sessão (padrão 14h)
JWT_EXPIRES_IN=14h

# Porta da API (padrão 4000)
PORT=4000

# Identidade do usuário master criado no primeiro acesso (bootstrap)
MASTER_CRM=32.394
MASTER_NAME=Nome do Administrador
